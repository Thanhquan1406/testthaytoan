# ===========================
# Server
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# MongoDB
# ===========================
MONGODB_URI=mongodb://localhost:27017/web_thi_trac_nghiem

# ===========================
# JWT
# ===========================
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=14
RESET_PASSWORD_EXPIRES_MINUTES=15
TWO_FA_CHALLENGE_EXPIRES_MINUTES=5

# JWT riêng cho thi ẩn danh (thời hạn ngắn hơn)
JWT_ANONYMOUS_EXPIRES_IN=4h

# ===========================
# CORS
# ===========================
CLIENT_URL=http://localhost:5173

# ===========================
# Google OAuth
# ===========================
GOOGLE_CLIENT_ID=your_google_client_id_here
TOTP_ISSUER=WEB_THI_TRAC_NGHIEM

# ===========================
# SMTP (Forgot password email)
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
MAIL_FROM=WEB THI TRAC NGHIEM <no-reply@example.com>
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# ===========================
# Upload
# ===========================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
